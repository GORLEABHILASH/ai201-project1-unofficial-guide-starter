# Copy this file to .env and replace the placeholder with your actual key.
# .env is listed in .gitignore — never commit your real key.
#
# Get a free Groq API key (no credit card required) at:
# https://console.groq.com

GROQ_API_KEY=your_key_here

# --- Reddit API (only needed if you run scrape_reddit.py) ---
# Reddit blocks unauthenticated scraping, so you need free API credentials:
#   1. Go to https://www.reddit.com/prefs/apps  (log in)
#   2. Click "create another app...", choose type "script"
#   3. name: anything (e.g. ai201-project) | redirect uri: http://localhost:8080
#   4. After creating: CLIENT_ID is the string under the app name (top-left),
#      CLIENT_SECRET is the "secret" field.
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
